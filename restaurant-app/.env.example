NODE_ENV=production
PORT=5000

# Base de données MySQL (PlanetScale ou autre)
DB_HOST=
DB_PORT=3306
DB_NAME=tsaralaza_restaurant
DB_USER=
DB_PASSWORD=

# JWT
JWT_SECRET=remplace-par-un-long-secret-aleatoire
JWT_EXPIRES_IN=12h

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="TSARALAZA <noreply@tsaralaza.mg>"

# Cloudinary (pour les uploads d'images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
